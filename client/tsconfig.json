{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,

    "allowJs": false,
    "checkJs": false,

    "types": ["@testing-library/jest-dom"]
  },
  "include": ["src/**/*"]
}